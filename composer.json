{
    "name": "einundzwanzig/group",
    "description": "Nostr-Community-Chat (Spaces/Räume/Directory/Login) für EINUNDZWANZIG — als wiederverwendbares Laravel-Package.",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/console": "^13.0",
        "livewire/livewire": "^4.1",
        "swentel/nostr-php": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "App\\Chat\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "App\\Chat\\ChatServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
